# === Mail servers and boxes ===
# IMAP server
IMAP_SERVER="imap.yandex.ru"

# IMAP port
IMAP_PORT=993

# SMTP server
SMTP_SERVER="smtp.yandex.ru"

# SMTP port
SMTP_PORT=465

# mailbox
MAILBOX_NAME=your-email@yandex.ru

# pwd user password
MAILBOX_APP_PASSWORD=your-app-password

# === 7Rights ===
SEVEN_RIGHTS_API_BASE_URL=https://lk.7rights.ru/
SEVEN_RIGHTS_API_VERSION=api/v1/
SEVEN_RIGHTS_API_KEY=your-api-key
SEVEN_RIGHTS_API_AWAIT_TIMEOUT=30

# === Mail server type (INTERNET=Yandex IMAP/SMTP, CORPORATE=MS Exchange EWS) ===
MAIL_SERVER=CORPORATE

# === Run mode (for project_root): dev|prod ===
APP_ENV=prod

# === Режим логирования: DEBUG|INFO|WARNING|ERROR|CRITICAL ===
LOG_LEVEL=INFO

# === RFQ Pipeline flags ===
# Пропустить медленный PUT запрос для поставщиков
IS_SKIP_PUT_RFQ_SUPPLIER_GROUP_IDS=false
# Искать существующий RFQ по названию перед созданием (true для продакшен)
IS_SEARCH_EXISTING_RFQ_BEFORE_POST=true

# === Exchange settings (probably) ===
EXCHANGE_USERNAME=COMPANY\company_user_acount
EXCHANGE_PASSWORD=company_user_acount_password
EXCHANGE_SERVER=mail.company.local
# Указываем адрес ящика, который нужно проверять и от имени которого слать ответы:
PRIMARY_SMTP_ADDRESS=nikolavtologistov@company.ru # supposedly pre-existing